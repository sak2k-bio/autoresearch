# AutoResearch Bio-Medical Pipeline Environment Variables

# Required API keys
TAVILY_API_KEY=your_tavily_api_key_here

# Primary Gemini API key (required)
GEMINI_API_KEY_1=your_primary_gemini_key_here
# Gemini model to use (defaults to gemini-1.5-pro if not specified)
GEMINI_MODEL=gemini-1.5-pro
# Optional backup keys (recommended for uninterrupted access)
GEMINI_API_KEY_2=your_backup_gemini_key_1
GEMINI_API_KEY_3=your_backup_gemini_key_2
GEMINI_API_KEY_4=your_backup_gemini_key_3
GEMINI_API_KEY_5=your_backup_gemini_key_4

# Optional LinkedIn API token for auto-publishing (if using GitHub Actions)
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here

# Optional email settings for notifications (if using GitHub Actions)
EMAIL_USERNAME=your_email_username
EMAIL_PASSWORD=your_email_password

# Optional Slack webhook for notifications (if using GitHub Actions)
SLACK_WEBHOOK_URL=your_slack_webhook_url